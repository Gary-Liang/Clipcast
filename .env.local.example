# Database (Docker PostgreSQL)
DATABASE_URL=postgresql://podcastuser:podcastpass123@localhost:5432/podcasttoclip

# Deepgram API
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Cloudflare R2 (S3-compatible storage)
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
R2_BUCKET_NAME=podcasttoclip

# R2_PUBLIC_DOMAIN is optional - only needed if you want public URLs
# R2_PUBLIC_DOMAIN=your-r2-public-domain.com

# Node Environment
NODE_ENV=development
