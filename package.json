{
  "name": "clipcast",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/cleanup.js && next dev",
    "dev:no-clean": "next dev",
    "postinstall": "prisma generate",
    "build": "prisma db push --accept-data-loss && next build",
    "start": "next start",
    "lint": "next lint",
    "clean": "node scripts/cleanup.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:reset": "prisma db push --force-reset",
    "validate": "node scripts/validate-env.js",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f postgres",
    "remotion:preview": "remotion preview src/remotion/Root.tsx",
    "remotion:render": "remotion render src/remotion/Root.tsx PodcastClip out/video.mp4"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@aws-sdk/client-s3": "^3.695.0",
    "@aws-sdk/s3-request-presigner": "^3.695.0",
    "@clerk/nextjs": "^6.37.5",
    "@deepgram/sdk": "^3.7.0",
    "@prisma/client": "^6.2.0",
    "@remotion/bundler": "^4.0.422",
    "@remotion/cli": "^4.0.422",
    "@remotion/lambda": "^4.0.422",
    "@remotion/player": "^4.0.422",
    "@remotion/renderer": "^4.0.422",
    "@stripe/stripe-js": "^8.7.0",
    "date-fns": "^4.1.0",
    "inngest": "^3.52.1",
    "nanoid": "^5.0.9",
    "next": "^15.1.0",
    "node-fetch": "^2.7.0",
    "openai": "^6.22.0",
    "pg": "^8.18.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0",
    "remotion": "^4.0.422",
    "stripe": "^20.3.1",
    "svix": "^1.85.0",
    "zod": "3.22.3"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.0",
    "kill-port": "^2.0.1",
    "postcss": "^8.4.49",
    "prisma": "^6.2.0",
    "rimraf": "^6.1.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
